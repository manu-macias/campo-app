# Copiar a .env y completar con los datos de tu proyecto Supabase
# (Supabase → Project Settings → API). La anon key es pública (segura para el
# cliente); la seguridad real la da la RLS, no el secreto de esta key.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
